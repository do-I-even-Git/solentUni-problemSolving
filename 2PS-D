#include <stdio.h>

int main()
{

    char movieType = 'A';
    char ticketType = 'P';
    float ticketPrice = 00.00;

    
        switch(movieType) {
            
            case 'A':
            ticketPrice = 10.00;
            break;
            case 'C':
            ticketPrice = 08.00;
            break;
            case 'H':
            ticketPrice = 09.00;
            break;
            
        }
    
        
        switch(ticketType){
            
            case 'S':
            ticketPrice+0;
            break;
            case 'P':
            ticketPrice = (ticketPrice + 05.00);
            break;
            
        }
    

        printf("Movie type is: %c.\nTicket type is: %c.\n", movieType, ticketType);
        printf("\nTicket price therefore is: %2f.\n", ticketPrice);


    return 0;
    
}
